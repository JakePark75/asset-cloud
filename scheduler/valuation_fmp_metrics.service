[Unit]
Description=Valuation FMP Metrics Engine (fmp_metrics snapshot upsert)
After=network.target postgresql.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/asset-cloud/scheduler
ExecStart=/usr/bin/python3 /home/ubuntu/asset-cloud/scheduler/valuation_fmp_metrics.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
